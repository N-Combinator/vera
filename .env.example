# Vera configuration — copy to `.env` and fill in your LLM provider.
# Every value is optional; unset means Vera uses local Ollama defaults.

# === LLM PROVIDER — uncomment ONE block ===
# VERA_LLM_PROVIDER selects the backend; without it Vera defaults to "ollama",
# so setting a key alone is not enough — uncomment the matching provider line too.

# Anthropic (Claude)
# VERA_LLM_PROVIDER=anthropic
# VERA_LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=your-key-here

# OpenRouter (Claude, GPT, Gemini, etc.)
# VERA_LLM_PROVIDER=openrouter
# VERA_LLM_MODEL=anthropic/claude-sonnet-4-6
# OPENROUTER_API_KEY=your-key-here

# OpenAI (GPT)
# VERA_LLM_PROVIDER=openai
# VERA_LLM_MODEL=gpt-4o
# OPENAI_API_KEY=your-key-here

# Ollama (local model) — this is the default if nothing above is set
# VERA_LLM_PROVIDER=ollama
# VERA_LLM_MODEL=llama3            # use a vision model (e.g. llama3.2-vision) for `describe`
# VERA_LLM_ENDPOINT=http://localhost:11434

# === OPTIONAL ===
# VERA_FIX_ROOT=./src              # restrict the folder `fix --apply` may write to
